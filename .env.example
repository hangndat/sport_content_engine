DATABASE_URL=postgresql://user:password@localhost:5432/sport_content_engine
REDIS_URL=redis://localhost:16379

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=sport-content
S3_REGION=us-east-1
S3_USE_SSL=false

OPENAI_API_KEY=sk-...

# AI Entity: bổ sung teams/players/contentType bằng LLM khi regex trả ít (default: true)
USE_AI_ENTITY_EXTRACT=true
AI_ENTITY_LIMIT=30

# AI Cluster: dùng embedding cosine similarity bổ sung Jaccard (khi có API key)
# Giúp gom "MU thắng Chelsea" vs "Man United đánh bại Chelsea". Tắt: USE_AI_CLUSTER=false
USE_AI_CLUSTER=true

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

PORT=3000
NODE_ENV=development

# A=draft only | B=semi-auto | C=full auto
MODERATION_MODE=A

# Scheduled ingest (ms). 0 = tắt. 7200000 = 2h
INGEST_INTERVAL_MS=0
